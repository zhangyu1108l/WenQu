# ============================================================
# WenQu Docker environment variable template
# ============================================================
# Copy this file to .env in the project root and fill real values there.
#   cp .env.example .env
#
# .env.example is safe to commit because it contains placeholders only.
# .env contains real passwords, JWT secrets, and API keys. Never commit .env.
#
# Changing these values normally does not require rebuilding images.
# Run docker-compose up -d to recreate/restart affected containers.
# ============================================================

# ============================================
# MySQL config
# ============================================
# How to get: choose your own MySQL root administrator password.
# Format: non-empty string; prefer 16+ chars and avoid quotes, spaces, and shell metacharacters.
# Rebuild needed after change: no; run docker-compose up -d. Existing initialized volumes may keep old credentials.
MYSQL_ROOT_PASSWORD=changeme_root

# How to get: project default database name.
# Format: MySQL database name; prefer lowercase letters, digits, and underscores.
# Rebuild needed after change: no; run docker-compose up -d. Existing initialized volumes will not rename automatically.
MYSQL_DATABASE=kb_system

# How to get: choose the application database user for kb-app.
# Format: MySQL user name; prefer letters, digits, and underscores.
# Rebuild needed after change: no; run docker-compose up -d.
MYSQL_USER=kb

# How to get: choose the application database password for MYSQL_USER.
# Format: non-empty string; prefer 16+ chars and avoid quotes, spaces, and shell metacharacters.
# Rebuild needed after change: no; run docker-compose up -d. Existing users may need manual password sync.
MYSQL_PASSWORD=changeme_kb

# How to get: Docker Compose service name.
# Format: hostname; inside Docker use mysql, not localhost.
# Rebuild needed after change: no; run docker-compose up -d.
MYSQL_HOST=mysql

# How to get: MySQL container internal port.
# Format: numeric port.
# Rebuild needed after change: no; run docker-compose up -d. Usually keep 3306.
MYSQL_PORT=3306

# ============================================
# Redis config
# ============================================
# This project leaves Redis password empty by default. Add one in production.
# If REDIS_PASSWORD is set, keep redis, app, and gateway configs in sync.

# How to get: Docker Compose service name.
# Format: hostname; inside Docker use redis, not localhost.
# Rebuild needed after change: no; run docker-compose up -d.
REDIS_HOST=redis

# How to get: Redis container internal port.
# Format: numeric port.
# Rebuild needed after change: no; run docker-compose up -d. Usually keep 6379.
REDIS_PORT=6379

# How to get: leave empty for no Redis password, or generate a strong password for production.
# Format: may be empty; if set, redis, app, and gateway must use the same value.
# Rebuild needed after change: no; run docker-compose up -d.
REDIS_PASSWORD=

# ============================================
# MinIO config for application document storage
# This is separate from Milvus internal MinIO.
# ============================================
# How to get: choose the application MinIO root user; also used as app access key.
# Format: at least 3 chars; prefer letters and digits.
# Rebuild needed after change: no; run docker-compose up -d. Existing initialized volumes may keep old credentials.
MINIO_ROOT_USER=minioadmin

# How to get: choose the application MinIO root password; also used as app secret key.
# Format: at least 8 chars; prefer 16+ chars and avoid quotes, spaces, and shell metacharacters.
# Rebuild needed after change: no; run docker-compose up -d. Existing initialized volumes may keep old credentials.
MINIO_ROOT_PASSWORD=changeme_minio_at_least_8_chars

# How to get: Docker Compose internal URL for the application MinIO service.
# Format: http(s) URL; inside Docker use minio, not localhost.
# Rebuild needed after change: no; run docker-compose up -d.
MINIO_ENDPOINT=http://minio:9000

# ============================================
# Milvus config
# ============================================
# How to get: Docker Compose service name.
# Format: hostname; inside Docker use milvus, not localhost.
# Rebuild needed after change: no; run docker-compose up -d.
MILVUS_HOST=milvus

# How to get: Milvus gRPC internal port.
# Format: numeric port.
# Rebuild needed after change: no; run docker-compose up -d. Usually keep 19530.
MILVUS_PORT=19530

# ============================================
# JWT config
# ============================================
# How to get: generate a random string, for example openssl rand -base64 48.
# Format: at least 32 chars; app and gateway must use the exact same value.
# Rebuild needed after change: no; run docker-compose up -d. Existing tokens become invalid.
JWT_SECRET=change_this_to_a_random_string_at_least_32_characters

# How to get: project default.
# Format: seconds; 3600 means 1 hour. Current Java config stores token TTL internally as milliseconds.
# Rebuild needed after change: no. If later mapped into Spring config, convert to milliseconds or adjust code.
JWT_ACCESS_EXPIRE=3600

# How to get: project default.
# Format: seconds; 604800 means 7 days. Current Java config stores token TTL internally as milliseconds.
# Rebuild needed after change: no. If later mapped into Spring config, convert to milliseconds or adjust code.
JWT_REFRESH_EXPIRE=604800

# ============================================
# AI model config
# ============================================
# How to get: create a DeepSeek API key at https://platform.deepseek.com.
# Format: DeepSeek API key, commonly starting with sk-. Do not put a real key in .env.example.
# Rebuild needed after change: no; run docker-compose up -d.
DEEPSEEK_API_KEY=sk-your-deepseek-key

# How to get: DeepSeek OpenAI-compatible base URL.
# Format: https URL; do not include concrete endpoint paths such as /v1/chat/completions.
# Rebuild needed after change: no; run docker-compose up -d.
DEEPSEEK_BASE_URL=https://api.deepseek.com

# How to get: create a Zhipu AI API key at https://open.bigmodel.cn.
# Format: Zhipu key, commonly your-zhipu-key.your-zhipu-secret. Do not put a real key in .env.example.
# Rebuild needed after change: no; run docker-compose up -d.
ZHIPU_API_KEY=your-zhipu-key.your-zhipu-secret

# How to get: Zhipu OpenAI-compatible base URL.
# Format: https URL; do not include /embeddings because the code adds that path.
# Rebuild needed after change: no; run docker-compose up -d.
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ============================================
# Python sidecars and internal callback config
# ============================================
# How to get: Docker Compose internal URL for the parser sidecar.
# Format: http URL; inside Docker use parser, not localhost.
# Rebuild needed after change: no; run docker-compose up -d.
PARSER_BASE_URL=http://parser:8090

# How to get: Docker Compose internal URL for the Ragas sidecar.
# Format: http URL; inside Docker use ragas-svc, not localhost.
# Rebuild needed after change: no; run docker-compose up -d.
RAGAS_BASE_URL=http://ragas-svc:8091

# How to get: internal callback URL from Ragas sidecar to kb-app.
# Format: http URL; path must be /internal/eval/callback.
# Rebuild needed after change: no; run docker-compose up -d.
EVAL_CALLBACK_URL=http://app:8081/internal/eval/callback

# How to get: internal base URL from Ragas sidecar to kb-app.
# Format: http URL; inside Docker use app, not localhost.
# Rebuild needed after change: no; run docker-compose up -d.
JAVA_APP_BASE_URL=http://app:8081

# ============================================
# Gateway routing config
# ============================================
# How to get: internal URL from gateway to kb-app.
# Format: http URL; inside Docker use app, not localhost.
# Rebuild needed after change: no; run docker-compose up -d.
APP_SERVICE_URL=http://app:8081
