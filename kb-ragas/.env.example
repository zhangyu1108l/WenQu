# DeepSeek API, used by Ragas to call the LLM for metric judgment.
# Format: keep the sk- prefix from the DeepSeek console.
DEEPSEEK_API_KEY=sk-xxxx

# DeepSeek OpenAI-compatible API base URL.
# Format: full HTTPS base URL, without a trailing path for chat completions.
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Zhipu Embedding API, used to vectorize evaluation questions.
# Format: key pair copied from the Zhipu console, usually xxxx.xxxx.
ZHIPU_API_KEY=xxxx.xxxx

# Zhipu OpenAI-compatible API base URL for embedding requests.
# Format: full HTTPS base URL for the v4 API.
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Java main service base URL for evaluation callbacks.
# Format: service name and internal port in Docker Compose.
JAVA_APP_BASE_URL=http://app:8081

# Port exposed by this Ragas sidecar.
# Format: numeric TCP port, fixed to 8091 by the architecture document.
PORT=8091
