# ============================================================
# 问渠 WenQu Docker 环境变量模板
# ============================================================
# 将此文件复制为项目根目录下的 .env，并在 .env 中填写真实配置值。
#   复制命令：cp .env.example .env
#
# .env.example 只包含占位符，可以安全提交到仓库。
# .env 包含真实密码、JWT 密钥和 API Key，禁止提交。
#
# 修改这些值通常不需要重新构建镜像。
# 执行 docker-compose up -d 可重建或重启受影响的容器。
# ============================================================

# ============================================
# 通用运行配置
# ============================================
# 获取方式：使用项目默认时区。
# 格式：IANA 时区字符串，通常保持 Asia/Shanghai。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
TZ=Asia/Shanghai

# 获取方式：Docker Compose 使用的 Spring profile。
# 格式：保持 docker，除非同时新增匹配的 Spring profile 配置。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
SPRING_PROFILES_ACTIVE=docker

# 获取方式：kb-app 容器内部端口。
# 格式：数字端口；保持 8081，确保与 kb-app Dockerfile EXPOSE 和健康检查一致。
# 修改后是否需要重建：如果修改应用监听端口，则需要。
APP_SERVER_PORT=8081

# 获取方式：Spring Boot 使用的 MySQL JDBC 驱动类。
# 格式：Java 类名，通常保持 com.mysql.cj.jdbc.Driver。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# ============================================
# MySQL 配置
# ============================================
# 获取方式：自行设置 MySQL root 管理员密码。
# 格式：非空字符串；建议 16 位以上，避免引号、空格和 shell 特殊字符。
# 修改后是否需要重建：不需要；执行 docker-compose up -d。已初始化的数据卷可能保留旧凭据。
MYSQL_ROOT_PASSWORD=changeme_root

# 获取方式：使用项目默认数据库名。
# 格式：MySQL 数据库名；建议使用小写字母、数字和下划线。
# 修改后是否需要重建：不需要；执行 docker-compose up -d。已初始化的数据卷不会自动改名。
MYSQL_DATABASE=kb_system

# 获取方式：为 kb-app 设置应用数据库用户。
# 格式：MySQL 用户名；建议使用字母、数字和下划线。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
MYSQL_USER=kb

# 获取方式：为 MYSQL_USER 设置应用数据库密码。
# 格式：非空字符串；建议 16 位以上，避免引号、空格和 shell 特殊字符。
# 修改后是否需要重建：不需要；执行 docker-compose up -d。已有用户可能需要手动同步密码。
MYSQL_PASSWORD=changeme_kb

# 获取方式：Docker Compose 服务名。
# 格式：主机名；Docker 内使用 mysql，不使用 localhost。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
MYSQL_HOST=mysql

# 获取方式：MySQL 容器内部端口。
# 格式：数字端口。
# 修改后是否需要重建：不需要；执行 docker-compose up -d。通常保持 3306。
MYSQL_PORT=3306

# 获取方式：kb-app 在 Docker 内连接 MySQL 使用的 JDBC URL。
# 格式：jdbc:mysql://mysql:3306/<database>?...；Docker 内使用 mysql，不使用 localhost。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/kb_system?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true

# ============================================
# Redis 配置
# ============================================
# 本项目默认 Redis 密码为空；生产环境请设置强密码。
# 如果设置 REDIS_PASSWORD，需要保持 redis、app 和 gateway 配置一致。

# 获取方式：Docker Compose 服务名。
# 格式：主机名；Docker 内使用 redis，不使用 localhost。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
REDIS_HOST=redis

# 获取方式：Redis 容器内部端口。
# 格式：数字端口。
# 修改后是否需要重建：不需要；执行 docker-compose up -d。通常保持 6379。
REDIS_PORT=6379

# 获取方式：无 Redis 密码时留空；生产环境请生成强密码。
# 格式：可为空；如果设置，redis、app 和 gateway 必须使用相同值。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
REDIS_PASSWORD=

# ============================================
# 应用文档存储使用的 MinIO 配置
# 该 MinIO 与 Milvus 内部 MinIO 相互独立。
# ============================================
# 获取方式：设置应用 MinIO root 用户，同时作为 app access key 使用。
# 格式：至少 3 个字符；建议使用字母和数字。
# 修改后是否需要重建：不需要；执行 docker-compose up -d。已初始化的数据卷可能保留旧凭据。
MINIO_ROOT_USER=minioadmin

# 获取方式：设置应用 MinIO root 密码，同时作为 app secret key 使用。
# 格式：至少 8 个字符；建议 16 位以上，避免引号、空格和 shell 特殊字符。
# 修改后是否需要重建：不需要；执行 docker-compose up -d。已初始化的数据卷可能保留旧凭据。
MINIO_ROOT_PASSWORD=changeme_minio_at_least_8_chars

# 获取方式：应用 MinIO 服务在 Docker Compose 内部的 URL。
# 格式：http(s) URL；Docker 内使用 minio，不使用 localhost。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
MINIO_ENDPOINT=http://minio:9000

# ============================================
# Milvus 配置
# ============================================
# 获取方式：Docker Compose 服务名。
# 格式：主机名；Docker 内使用 milvus，不使用 localhost。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
MILVUS_HOST=milvus

# 获取方式：Milvus gRPC 内部端口。
# 格式：数字端口。
# 修改后是否需要重建：不需要；执行 docker-compose up -d。通常保持 19530。
MILVUS_PORT=19530

# 获取方式：Milvus 容器使用的内部 etcd 端点。
# 格式：Docker 网络内的 host:port，通常保持 milvus-etcd:2379。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
MILVUS_ETCD_ENDPOINTS=milvus-etcd:2379

# 获取方式：Milvus 使用的内部对象存储端点。
# 格式：Docker 网络内的 host:port，通常保持 milvus-minio:9000。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
MILVUS_MINIO_ADDRESS=milvus-minio:9000

# 获取方式：仅供 Milvus 内部 MinIO 使用的凭据。
# 格式：非空字符串；与 MINIO_ROOT_USER/PASSWORD 相互独立。
# 修改后是否需要重建：不需要；已初始化的数据卷可能保留旧凭据。
MILVUS_MINIO_ACCESS_KEY=minioadmin
MILVUS_MINIO_SECRET_KEY=minioadmin

# 获取方式：Milvus standalone 的 etcd 调优默认值。
# 格式：etcd 接受的字符串或数字，通常保持这些默认值。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
ETCD_AUTO_COMPACTION_MODE=revision
ETCD_AUTO_COMPACTION_RETENTION=1000
ETCD_QUOTA_BACKEND_BYTES=4294967296
ETCD_SNAPSHOT_COUNT=50000

# ============================================
# JWT 配置
# ============================================
# 获取方式：生成随机字符串，例如 openssl rand -base64 48。
# 格式：至少 32 个字符；app 和 gateway 必须使用完全相同的值。
# 修改后是否需要重建：不需要；执行 docker-compose up -d。已有 token 会失效。
JWT_SECRET=change_this_to_a_random_string_at_least_32_characters

# 获取方式：使用项目默认值。
# 格式：秒；3600 表示 1 小时。当前 Java 配置内部以毫秒保存 token TTL。
# 修改后是否需要重建：不需要。若后续映射到 Spring 配置，请转换为毫秒或调整代码。
JWT_ACCESS_EXPIRE=3600

# 获取方式：使用项目默认值。
# 格式：秒；604800 表示 7 天。当前 Java 配置内部以毫秒保存 token TTL。
# 修改后是否需要重建：不需要。若后续映射到 Spring 配置，请转换为毫秒或调整代码。
JWT_REFRESH_EXPIRE=604800

# ============================================
# AI 模型配置
# ============================================
# 获取方式：在 https://platform.deepseek.com 创建 DeepSeek API Key。
# 格式：DeepSeek API Key，通常以 sk- 开头。不要在 .env.example 中放真实密钥。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
DEEPSEEK_API_KEY=sk-your-deepseek-key

# 获取方式：DeepSeek OpenAI 兼容基础 URL。
# 格式：https URL；不要包含 /v1/chat/completions 之类的具体端点路径。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 获取方式：架构定义的对话模型和生成温度。
# 格式：模型名和小数温度；本项目保持 deepseek-chat。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_CHAT_TEMPERATURE=0.3

# 获取方式：在 https://open.bigmodel.cn 创建智谱 AI API Key。
# 格式：智谱 key，通常为 your-zhipu-key.your-zhipu-secret。不要在 .env.example 中放真实密钥。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
ZHIPU_API_KEY=your-zhipu-key.your-zhipu-secret

# 获取方式：智谱 OpenAI 兼容基础 URL。
# 格式：https URL；不要包含 /embeddings，代码会自动追加该路径。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 获取方式：架构定义的 embedding 模型和向量维度。
# 格式：模型名和整数维度；本项目保持 embedding-3 和 2048。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
ZHIPU_EMBEDDING_MODEL=embedding-3
ZHIPU_EMBEDDING_DIMENSIONS=2048

# ============================================
# Python 侧车和内部回调配置
# ============================================
# 获取方式：解析侧车在 Docker Compose 内部的 URL。
# 格式：http URL；Docker 内使用 parser，不使用 localhost。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
PARSER_BASE_URL=http://parser:8090

# 获取方式：Ragas 侧车在 Docker Compose 内部的 URL。
# 格式：http URL；Docker 内使用 ragas-svc，不使用 localhost。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
RAGAS_BASE_URL=http://ragas-svc:8091

# 获取方式：Ragas 侧车回调 kb-app 的内部 URL。
# 格式：http URL；路径必须是 /internal/eval/callback。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
EVAL_CALLBACK_URL=http://app:8081/internal/eval/callback

# 获取方式：Ragas 侧车访问 kb-app 的内部基础 URL。
# 格式：http URL；Docker 内使用 app，不使用 localhost。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
JAVA_APP_BASE_URL=http://app:8081

# ============================================
# Gateway 路由配置
# ============================================
# 获取方式：gateway 访问 kb-app 的内部 URL。
# 格式：http URL；Docker 内使用 app，不使用 localhost。
# 修改后是否需要重建：不需要；执行 docker-compose up -d 即可。
APP_SERVICE_URL=http://app:8081
