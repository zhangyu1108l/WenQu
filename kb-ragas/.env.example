# DeepSeek API Key，供 Ragas 调用 LLM 进行指标判断。
# 格式：保留 DeepSeek 控制台中的 sk- 前缀。
DEEPSEEK_API_KEY=sk-xxxx

# DeepSeek OpenAI 兼容 API 基础 URL。
# 格式：完整 HTTPS 基础 URL，不包含 chat completions 端点路径。
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 智谱 Embedding API，用于向量化评估问题。
# 格式：从智谱控制台复制的密钥对，通常为 xxxx.xxxx。
ZHIPU_API_KEY=xxxx.xxxx

# 智谱 OpenAI 兼容 API 基础 URL，用于 embedding 请求。
# 格式：v4 API 的完整 HTTPS 基础 URL。
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 评估回调使用的 Java 主服务基础 URL。
# 格式：Docker Compose 中的服务名和内部端口。
JAVA_APP_BASE_URL=http://app:8081

# Ragas 侧车暴露的端口。
# 格式：数字 TCP 端口，架构文档固定为 8091。
PORT=8091
