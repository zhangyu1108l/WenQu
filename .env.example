# ============================================================
# 问渠（WenQu）— 环境变量模板
# 使用方法：复制本文件为 .env，填入实际值后启动
#   cp .env.example .env
# ============================================================

# ---- MySQL 配置 ----
# root 用户密码（必填，用于数据库初始化和管理）
MYSQL_ROOT_PASSWORD=your_root_password_here
# 业务数据库名称（默认 kb_system，与 Spring Boot 配置保持一致）
MYSQL_DATABASE=kb_system
# 业务数据库用户名（应用连接使用，非 root）
MYSQL_USER=kb
# 业务数据库用户密码（必填，应用连接时使用）
MYSQL_PASSWORD=your_mysql_password_here
# 宿主机映射端口（默认 3306，端口冲突时可修改）
MYSQL_PORT=3306

# ---- Redis 配置 ----
# Redis 访问密码（必填，用于 JWT 黑名单和对话历史缓存）
REDIS_PASSWORD=your_redis_password_here
# 宿主机映射端口（默认 6379，端口冲突时可修改）
REDIS_PORT=6379

# ---- MinIO 配置 ----
# MinIO 管理员用户名（同时作为 Milvus 的存储凭证）
MINIO_ROOT_USER=minioadmin
# MinIO 管理员密码（同时作为 Milvus 的存储凭证，建议修改默认值）
MINIO_ROOT_PASSWORD=your_minio_password_here
# MinIO API 端口（默认 9000，Java 服务通过此端口访问）
MINIO_PORT=9000
# MinIO Web 控制台端口（默认 9001，浏览器访问 http://localhost:9001 管理文件）
MINIO_CONSOLE_PORT=9001

# ---- Milvus 配置 ----
# Milvus gRPC 端口（默认 19530，Java 服务通过此端口连接向量库）
MILVUS_PORT=19530

# ---- AI 服务 API Key（本地开发 Java 服务时使用，不在 Docker Compose 中引用）----
# DeepSeek Chat API Key（用于问题改写和 RAG 流式生成）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# 智谱 AI API Key（用于 embedding-3 向量化，维度 2048）
ZHIPU_API_KEY=your_zhipu_api_key_here